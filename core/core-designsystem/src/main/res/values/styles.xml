<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.DocVault" parent="Theme.Material3.DayNight.NoActionBar" />

    <style name="Theme.PlayCore.Transparent" parent="android:Theme">
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:backgroundDimEnabled">false</item>
    </style>
    <style name="DocVault.TextAppearance.Title" parent="TextAppearance.Material3.TitleLarge">
        <item name="android:textColor">@color/docvault_on_surface</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="DocVault.TextAppearance.Body" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textColor">@color/docvault_on_surface_variant</item>
    </style>

    <style name="DocVault.TextAppearance.Label" parent="TextAppearance.Material3.LabelSmall">
        <item name="android:textColor">@color/docvault_on_surface_variant</item>
    </style>

    <style name="DocVault.Button.Primary" parent="Widget.Material3.Button">
        <item name="android:minHeight">@dimen/button_height</item>
        <item name="android:textAllCaps">false</item>
        <item name="cornerRadius">@dimen/corner_radius_md</item>
    </style>

    <style name="DocVault.Button.Outlined" parent="Widget.Material3.Button.OutlinedButton">
        <item name="android:minHeight">@dimen/button_height</item>
        <item name="android:textAllCaps">false</item>
        <item name="cornerRadius">@dimen/corner_radius_md</item>
    </style>

    <style name="DocVault.Card" parent="Widget.Material3.CardView.Elevated">
        <item name="cardCornerRadius">@dimen/corner_radius_md</item>
        <item name="cardElevation">2dp</item>
        <item name="android:layout_margin">@dimen/spacing_sm</item>
    </style>

</resources>